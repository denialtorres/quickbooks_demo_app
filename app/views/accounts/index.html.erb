<div class="min-h-screen bg-[#faf9f5] py-12">
  <div class="container mx-auto px-4">
    <!-- Welcome Header -->
    <div class="bg-white rounded-xl shadow-lg p-8 mb-8 border border-[#e8e6dc]">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-4xl font-bold text-[#141413] font-display mb-2">
            Welcome, <%= @user.email.split('@').first&.capitalize %>!
          </h1>
          <p class="text-[#b0aea5] font-sans text-lg">
            You're logged in as <span class="font-semibold text-[#141413]"><%= @user.email %></span>
          </p>
        </div>
        <div class="flex items-center gap-3">
          <%= button_to "Log Out", destroy_user_session_path, method: :delete,
              class: "bg-[#d97757] text-[#faf9f5] px-6 py-2 rounded-lg hover:bg-[#c06040] transition-colors font-display font-medium" %>
        </div>
      </div>

      <div class="border-t border-[#e8e6dc] pt-6">
        <% if @account.present? %>
          <div class="bg-[#788c5d]/10 rounded-lg p-6 border border-[#788c5d]/20">
            <h2 class="text-2xl font-bold text-[#141413] font-display mb-4">Your Organization</h2>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-[#788c5d] rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-[#faf9f5]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5-10v5a2 2 0 012 2h10a2 2 0 012-2V7a2 2 0 00-2-2h-2m-2 0a2 2 0 00-2 2v2m10-6V9a2 2 0 00-2-2h-2"></path>
                </svg>
              </div>
              <div>
                <p class="text-sm text-[#b0aea5] font-sans">Company Name</p>
                <p class="text-2xl font-bold text-[#141413] font-display"><%= @account.name %></p>
              </div>
            </div>
          </div>
        <% else %>
          <div class="bg-[#d97757]/10 rounded-lg p-6 border border-[#d97757]/20">
            <p class="text-[#d97757] font-sans">
              ⚠️ You're not associated with an organization. Please contact support.
            </p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-xl shadow-lg p-6 border border-[#e8e6dc]">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-[#141413] font-display">Account ID</h3>
          <div class="w-10 h-10 bg-[#6a9bcc]/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-[#6a9bcc]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-16M8 24l-4-4m4 4l4 4m4-16"></path>
            </svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-[#6a9bcc] font-display"><%= @account&.identifier || 'N/A' %></p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-6 border border-[#e8e6dc]">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-[#141413] font-display">Member Since</h3>
          <div class="w-10 h-10 bg-[#d97757]/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-[#d97757]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 0V3m-9 18h18"></path>
              <circle cx="12" cy="12" r="4"></circle>
            </svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-[#d97757] font-display"><%= @user.created_at.strftime("%B %d, %Y") %></p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-6 border border-[#e8e6dc]">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-[#141413] font-display">Status</h3>
          <div class="w-10 h-10 bg-[#788c5d]/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-[#788c5d]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <p class="text-lg font-semibold text-[#788c5d] font-display">Active</p>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="bg-white rounded-xl shadow-lg p-6 border border-[#e8e6dc]">
      <h2 class="text-2xl font-bold text-[#141413] font-display mb-4">Quick Actions</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <%= link_to edit_user_registration_path(@user), class: "flex items-center gap-3 p-4 bg-[#faf9f5] rounded-lg hover:bg-[#e8e6dc] transition-colors border border-[#e8e6dc]" do %>
          <div class="w-10 h-10 bg-[#d97757]/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-[#d97757]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5h-5M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-[#141413] font-display">Edit Profile</h3>
            <p class="text-sm text-[#b0aea5] font-sans">Update your personal information</p>
          </div>
        <% end %>

        <%= link_to "#", class: "flex items-center gap-3 p-4 bg-[#faf9f5] rounded-lg hover:bg-[#e8e6dc] transition-colors border border-[#e8e6dc]" do %>
            <div class="w-10 h-10 bg-[#6a9bcc]/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-[#6a9bcc]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 012 2V7a2 2 0 00-2-2h-2m-2 0a2 2 0 00-2 2v8a2 2 0 012 2V7a2 2 0 00-2-2h-2m-2 0a2 2 0 00-2 2v8a2 2 0 012 2V7a2 2 0 00-2-2z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[#141413] font-display">Account Settings</h3>
              <p class="text-sm text-[#b0aea5] font-sans">Manage organization settings</p>
            </div>
          <% end %>

          <%= link_to qbo_account_accounts_path, class: "flex items-center gap-3 p-4 bg-[#faf9f5] rounded-lg hover:bg-[#e8e6dc] transition-colors border border-[#e8e6dc]" do %>
            <div class="w-10 h-10 bg-[#d97757]/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-[#d97757]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-[#141413] font-display">QuickBooks Online</h3>
              <p class="text-sm text-[#b0aea5] font-sans">Connect your QuickBooks account</p>
            </div>
          <% end %>

        <%= link_to "#", class: "flex items-center gap-3 p-4 bg-[#faf9f5] rounded-lg hover:bg-[#e8e6dc] transition-colors border border-[#e8e6dc]" do %>
          <div class="w-10 h-10 bg-[#788c5d]/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-[#788c5d]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v-3m-9 0v3m0 0v-3m-6-3h6m-5.714 0 5.714L7 10l4.286-4.286L11 11m-8 5 5 5-5"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-[#141413] font-display">Team Members</h3>
            <p class="text-sm text-[#b0aea5] font-sans">Manage your team</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
