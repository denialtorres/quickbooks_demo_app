<div class="min-h-screen flex items-center justify-center px-4 bg-light">
  <div class="max-w-md w-full bg-white rounded-lg shadow-lg p-8 border border-light-gray">
    <h2 class="text-3xl font-bold text-center text-dark mb-8 font-display">Change your password</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="field">
        <%= f.label :password, "New password", class: "block text-sm font-medium text-dark mb-2 font-sans" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-mid-gray mb-2 font-sans"><em>(<%= @minimum_password_length %> characters minimum)</em></p>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password",
            class: "w-full px-4 py-2 border border-light-gray rounded-lg focus:ring-2 focus:ring-orange focus:border-orange outline-none transition-colors bg-light text-dark font-sans" %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-dark mb-2 font-sans" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full px-4 py-2 border border-light-gray rounded-lg focus:ring-2 focus:ring-orange focus:border-orange outline-none transition-colors bg-light text-dark font-sans" %>
      </div>

      <div class="actions">
        <%= f.submit "Change my password",
            class: "w-full bg-orange text-light py-2 px-4 rounded-lg hover:bg-[#c06040] focus:ring-2 focus:ring-orange focus:ring-offset-2 outline-none transition-colors font-medium font-sans" %>
      </div>
    <% end %>

    <div class="mt-6 pt-6 border-t border-light-gray">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
