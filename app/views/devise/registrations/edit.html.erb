<div class="min-h-screen flex items-center justify-center px-4 bg-light">
  <div class="max-w-md w-full bg-white rounded-lg shadow-lg p-8 border border-light-gray">
    <h2 class="text-3xl font-bold text-center text-dark mb-8 font-display">Edit <%= resource_name.to_s.humanize %></h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= f.label :email, class: "block text-sm font-medium text-dark mb-2 font-sans" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-2 border border-light-gray rounded-lg focus:ring-2 focus:ring-orange focus:border-orange outline-none transition-colors bg-light text-dark font-sans" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="bg-[#d97757]/10 border border-[#d97757] rounded-lg p-4 text-[#141413] font-sans">
          Currently waiting confirmation for: <%= resource.unconfirmed_email %>
        </div>
      <% end %>

      <div class="field">
        <%= f.label :password, class: "block text-sm font-medium text-dark mb-2 font-sans" %>
        <i class="text-xs text-mid-gray font-sans">(leave blank if you don't want to change it)</i>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full px-4 py-2 border border-light-gray rounded-lg focus:ring-2 focus:ring-orange focus:border-orange outline-none transition-colors bg-light text-dark font-sans mt-2" %>
        <% if @minimum_password_length %>
          <p class="text-xs text-mid-gray mt-2 font-sans"><em><%= @minimum_password_length %> characters minimum</em></p>
        <% end %>
      </div>

      <div class="field">
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-dark mb-2 font-sans" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full px-4 py-2 border border-light-gray rounded-lg focus:ring-2 focus:ring-orange focus:border-orange outline-none transition-colors bg-light text-dark font-sans" %>
      </div>

      <div class="field">
        <%= f.label :current_password, class: "block text-sm font-medium text-dark mb-2 font-sans" %>
        <i class="text-xs text-mid-gray font-sans">(we need your current password to confirm your changes)</i>
        <%= f.password_field :current_password, autocomplete: "current-password",
            class: "w-full px-4 py-2 border border-light-gray rounded-lg focus:ring-2 focus:ring-orange focus:border-orange outline-none transition-colors bg-light text-dark font-sans mt-2" %>
      </div>

      <div class="actions">
        <%= f.submit "Update",
            class: "w-full bg-orange text-light py-2 px-4 rounded-lg hover:bg-[#c06040] focus:ring-2 focus:ring-orange focus:ring-offset-2 outline-none transition-colors font-medium font-sans" %>
      </div>
    <% end %>

    <div class="mt-8 pt-8 border-t border-light-gray">
      <h3 class="text-xl font-bold text-dark mb-4 font-display">Cancel my account</h3>
      <div class="text-[#141413] mb-4 font-sans">
        Unhappy? <%= button_to "Cancel my account", registration_path(resource_name),
            data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
            method: :delete,
            class: "bg-[#d97757] text-light py-2 px-4 rounded-lg hover:bg-[#c06040] focus:ring-2 focus:ring-orange focus:ring-offset-2 outline-none transition-colors font-medium font-sans" %>
      </div>
      <%= link_to "Back", :back, class: "text-[#d97757] hover:text-[#c06040] font-display transition-colors inline-block" %>
    </div>
  </div>
</div>
