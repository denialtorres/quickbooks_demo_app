<%- if controller_name != 'sessions' %>
  <div class="mt-4 text-center">
    <%= link_to "Log in", new_session_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium transition-colors" %>
  </div>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <div class="mt-4 text-center">
    <%= link_to "Sign up", new_registration_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium transition-colors" %>
  </div>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <div class="mt-4 text-center">
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-indigo-600 hover:text-indigo-800 font-medium transition-colors" %>
  </div>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <div class="mt-4 text-center">
    <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-sm text-gray-600 hover:text-indigo-800 transition-colors" %>
  </div>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <div class="mt-4 text-center">
    <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-sm text-gray-600 hover:text-indigo-800 transition-colors" %>
  </div>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <div class="mt-4 text-center">
      <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), class: "w-full bg-gray-100 text-gray-700 py-2 px-4 rounded-lg hover:bg-gray-200 transition-colors font-medium", data: { turbo: false } %>
    </div>
  <% end %>
<% end %>
