<div class="min-h-screen flex items-center justify-center px-4 bg-light">
  <div class="max-w-md w-full bg-white rounded-lg shadow-lg p-8 border border-light-gray">
    <h2 class="text-3xl font-bold text-center text-dark mb-8 font-display">Resend unlock instructions</h2>

    <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="field">
        <%= f.label :email, class: "block text-sm font-medium text-dark mb-2 font-sans" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-2 border border-light-gray rounded-lg focus:ring-2 focus:ring-orange focus:border-orange outline-none transition-colors bg-light text-dark font-sans" %>
      </div>

      <div class="actions">
        <%= f.submit "Resend unlock instructions",
            class: "w-full bg-orange text-light py-2 px-4 rounded-lg hover:bg-[#c06040] focus:ring-2 focus:ring-orange focus:ring-offset-2 outline-none transition-colors font-medium font-sans" %>
      </div>
    <% end %>

    <div class="mt-6 pt-6 border-t border-light-gray">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
