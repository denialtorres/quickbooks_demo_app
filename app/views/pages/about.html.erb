<div class="min-h-screen bg-[#faf9f5]">
  <!-- Header Section -->
  <div class="container mx-auto px-4 py-16">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold text-[#141413] mb-6 font-display">About Quickbooks Demo App</h1>
      <p class="text-xl text-[#141413] max-w-3xl mx-auto font-sans">
        We're building the future of business management tools, empowering users to work smarter and achieve more.
      </p>
    </div>

    <!-- Our Story Section -->
    <div class="bg-white rounded-xl shadow-lg p-12 mb-12 border border-[#e8e6dc]">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-[#141413] mb-6 font-display">Our Story</h2>
          <p class="text-[#b0aea5] mb-4 leading-relaxed font-sans">
            Quickbooks Demo App was born from a simple idea: make business management accessible to everyone. We believe that powerful tools shouldn't require complex setups or technical expertise.
          </p>
          <p class="text-[#b0aea5] mb-4 leading-relaxed font-sans">
            Our team of dedicated engineers and designers work tirelessly to create an intuitive platform that adapts to your workflow, not the other way around. Every feature is designed with user experience at its core.
          </p>
          <p class="text-[#b0aea5] leading-relaxed font-sans">
            Since our launch, we've helped thousands of businesses streamline their operations, save time, and focus on what matters most—growing their business.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-[#d97757]/10 rounded-lg p-6 text-center border border-[#d97757]/20">
            <div class="text-4xl font-bold text-[#d97757] mb-2 font-display">10K+</div>
            <div class="text-[#141413] font-sans">Active Users</div>
          </div>
          <div class="bg-[#788c5d]/10 rounded-lg p-6 text-center border border-[#788c5d]/20">
            <div class="text-4xl font-bold text-[#788c5d] mb-2 font-display">99.9%</div>
            <div class="text-[#141413] font-sans">Uptime</div>
          </div>
          <div class="bg-[#6a9bcc]/10 rounded-lg p-6 text-center border border-[#6a9bcc]/20">
            <div class="text-4xl font-bold text-[#6a9bcc] mb-2 font-display">50+</div>
            <div class="text-[#141413] font-sans">Features</div>
          </div>
          <div class="bg-[#d97757]/10 rounded-lg p-6 text-center border border-[#d97757]/20">
            <div class="text-4xl font-bold text-[#d97757] mb-2 font-display">24/7</div>
            <div class="text-[#141413] font-sans">Support</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Values Section -->
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-[#141413] mb-4 font-display">Our Core Values</h2>
      <p class="text-[#b0aea5] max-w-2xl mx-auto font-sans">
        These principles guide everything we do, from product development to customer support.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
        <div class="w-12 h-12 bg-[#788c5d]/10 rounded-lg flex items-center justify-center mb-4 border border-[#788c5d]/20">
          <svg class="w-6 h-6 text-[#788c5d]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-[#141413] mb-2 font-display">Quality</h3>
        <p class="text-[#b0aea5] text-sm font-sans">
          We never compromise on quality. Every feature is tested and polished to perfection.
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
        <div class="w-12 h-12 bg-[#6a9bcc]/10 rounded-lg flex items-center justify-center mb-4 border border-[#6a9bcc]/20">
          <svg class="w-6 h-6 text-[#6a9bcc]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-[#141413] mb-2 font-display">Collaboration</h3>
        <p class="text-[#b0aea5] text-sm font-sans">
          We believe in the power of teamwork, both internally and with our users.
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
        <div class="w-12 h-12 bg-[#d97757]/10 rounded-lg flex items-center justify-center mb-4 border border-[#d97757]/20">
          <svg class="w-6 h-6 text-[#d97757]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-[#141413] mb-2 font-display">Innovation</h3>
        <p class="text-[#b0aea5] text-sm font-sans">
          We constantly push boundaries and embrace new technologies to serve you better.
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
        <div class="w-12 h-12 bg-[#d97757]/10 rounded-lg flex items-center justify-center mb-4 border border-[#d97757]/20">
          <svg class="w-6 h-6 text-[#d97757]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-[#141413] mb-2 font-display">Customer Focus</h3>
        <p class="text-[#b0aea5] text-sm font-sans">
          Our users are at the heart of everything we do. Your success is our success.
        </p>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-[#141413] rounded-2xl p-12 text-center text-[#faf9f5] shadow-xl">
      <h2 class="text-4xl font-bold mb-4 font-display">Join Our Journey</h2>
      <p class="text-[#b0aea5] text-lg mb-8 max-w-2xl mx-auto font-sans">
        Be part of something bigger. Join our community and help shape the future of business management.
      </p>
      <% if user_signed_in? %>
        <%= link_to "Explore Features", "#", class: "bg-white text-[#141413] px-8 py-3 rounded-lg hover:bg-[#e8e6dc] transition-colors font-semibold shadow-lg hover:shadow-xl inline-block font-display" %>
      <% else %>
        <%= link_to "Get Started Today", new_user_registration_path, class: "bg-white text-[#141413] px-8 py-3 rounded-lg hover:bg-[#e8e6dc] transition-colors font-semibold shadow-lg hover:shadow-xl inline-block font-display" %>
      <% end %>
    </div>
  </div>
</div>
