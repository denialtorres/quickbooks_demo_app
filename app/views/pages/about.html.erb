<div class="min-h-screen bg-gradient-to-br from-indigo-50 to-purple-50">
  <!-- Header Section -->
  <div class="container mx-auto px-4 py-16">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold text-gray-900 mb-6">About Quickbooks Demo App</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        We're building the future of business management tools, empowering users to work smarter and achieve more.
      </p>
    </div>

    <!-- Our Story Section -->
    <div class="bg-white rounded-xl shadow-lg p-12 mb-12">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Our Story</h2>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Quickbooks Demo App was born from a simple idea: make business management accessible to everyone. We believe that powerful tools shouldn't require complex setups or technical expertise.
          </p>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Our team of dedicated engineers and designers work tirelessly to create an intuitive platform that adapts to your workflow, not the other way around. Every feature is designed with user experience at its core.
          </p>
          <p class="text-gray-600 leading-relaxed">
            Since our launch, we've helped thousands of businesses streamline their operations, save time, and focus on what matters most—growing their business.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-indigo-50 rounded-lg p-6 text-center">
            <div class="text-4xl font-bold text-indigo-600 mb-2">10K+</div>
            <div class="text-gray-600">Active Users</div>
          </div>
          <div class="bg-green-50 rounded-lg p-6 text-center">
            <div class="text-4xl font-bold text-green-600 mb-2">99.9%</div>
            <div class="text-gray-600">Uptime</div>
          </div>
          <div class="bg-purple-50 rounded-lg p-6 text-center">
            <div class="text-4xl font-bold text-purple-600 mb-2">50+</div>
            <div class="text-gray-600">Features</div>
          </div>
          <div class="bg-orange-50 rounded-lg p-6 text-center">
            <div class="text-4xl font-bold text-orange-600 mb-2">24/7</div>
            <div class="text-gray-600">Support</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Values Section -->
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Core Values</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        These principles guide everything we do, from product development to customer support.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow">
        <div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Quality</h3>
        <p class="text-gray-600 text-sm">
          We never compromise on quality. Every feature is tested and polished to perfection.
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow">
        <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Collaboration</h3>
        <p class="text-gray-600 text-sm">
          We believe in the power of teamwork, both internally and with our users.
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow">
        <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Innovation</h3>
        <p class="text-gray-600 text-sm">
          We constantly push boundaries and embrace new technologies to serve you better.
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow">
        <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Customer Focus</h3>
        <p class="text-gray-600 text-sm">
          Our users are at the heart of everything we do. Your success is our success.
        </p>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl p-12 text-center text-white shadow-xl">
      <h2 class="text-4xl font-bold mb-4">Join Our Journey</h2>
      <p class="text-indigo-100 text-lg mb-8 max-w-2xl mx-auto">
        Be part of something bigger. Join our community and help shape the future of business management.
      </p>
      <% if user_signed_in? %>
        <%= link_to "Explore Features", "#", class: "bg-white text-indigo-600 px-8 py-3 rounded-lg hover:bg-indigo-50 transition-colors font-semibold shadow-lg hover:shadow-xl inline-block" %>
      <% else %>
        <%= link_to "Get Started Today", new_user_registration_path, class: "bg-white text-indigo-600 px-8 py-3 rounded-lg hover:bg-indigo-50 transition-colors font-semibold shadow-lg hover:shadow-xl inline-block" %>
      <% end %>
    </div>
  </div>
</div>
