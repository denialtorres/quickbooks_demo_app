<div class="min-h-screen bg-gradient-to-br from-indigo-50 to-purple-50">
  <!-- Hero Section -->
  <div class="container mx-auto px-4 py-16">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold text-gray-900 mb-6">
        Welcome to Quickbooks Demo App
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
        A modern, user-friendly application designed to help you manage your business efficiently with powerful tools and intuitive features.
      </p>

      <div class="flex gap-4 justify-center">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", "#", class: "bg-indigo-600 text-white px-8 py-3 rounded-lg hover:bg-indigo-700 transition-colors font-semibold shadow-lg hover:shadow-xl" %>
        <% else %>
          <%= link_to "Get Started", new_user_registration_path, class: "bg-indigo-600 text-white px-8 py-3 rounded-lg hover:bg-indigo-700 transition-colors font-semibold shadow-lg hover:shadow-xl" %>
          <%= link_to "Sign In", new_user_session_path, class: "bg-white text-indigo-600 px-8 py-3 rounded-lg border-2 border-indigo-600 hover:bg-indigo-50 transition-colors font-semibold shadow-md hover:shadow-lg" %>
        <% end %>
      </div>
    </div>

    <!-- Features Section -->
    <div class="grid md:grid-cols-3 gap-8 mt-16">
      <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow">
        <div class="w-14 h-14 bg-indigo-100 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Fast & Efficient</h3>
        <p class="text-gray-600">
          Lightning-fast performance and streamlined workflows to help you get more done in less time.
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow">
        <div class="w-14 h-14 bg-green-100 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Secure & Reliable</h3>
        <p class="text-gray-600">
          Enterprise-grade security features to keep your data safe and accessible whenever you need it.
        </p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow">
        <div class="w-14 h-14 bg-purple-100 rounded-lg flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-3">Easy to Use</h3>
        <p class="text-gray-600">
          Intuitive interface designed with user experience in mind. No technical expertise required.
        </p>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="mt-20 bg-indigo-600 rounded-2xl p-12 text-center text-white shadow-xl">
      <h2 class="text-4xl font-bold mb-4">Ready to Get Started?</h2>
      <p class="text-indigo-100 text-lg mb-8 max-w-2xl mx-auto">
        Join thousands of users who are already experiencing the power of our platform.
      </p>
      <% if user_signed_in? %>
        <%= link_to "Go to Dashboard", "#", class: "bg-white text-indigo-600 px-8 py-3 rounded-lg hover:bg-indigo-50 transition-colors font-semibold shadow-lg hover:shadow-xl inline-block" %>
      <% else %>
        <%= link_to "Create Free Account", new_user_registration_path, class: "bg-white text-indigo-600 px-8 py-3 rounded-lg hover:bg-indigo-50 transition-colors font-semibold shadow-lg hover:shadow-xl inline-block" %>
      <% end %>
    </div>
  </div>
</div>
