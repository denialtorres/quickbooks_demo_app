<div class="min-h-screen bg-[#faf9f5]">
  <!-- Hero Section -->
  <div class="container mx-auto px-4 py-16">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-bold text-[#141413] mb-6 font-display">
        Welcome to Quickbooks Demo App
      </h1>
      <p class="text-xl text-[#141413] max-w-3xl mx-auto mb-8 font-sans">
        A multi-tenant business management application where each organization has its own isolated workspace.
        Sign up to create your account, or use one of our demo credentials to explore the platform.
      </p>

      <div class="flex gap-4 justify-center">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", "#", class: "bg-[#d97757] text-[#faf9f5] px-8 py-3 rounded-lg hover:bg-[#c06040] transition-colors font-semibold shadow-lg hover:shadow-xl font-display" %>
        <% else %>
          <%= link_to "Get Started", new_user_registration_path, class: "bg-[#d97757] text-[#faf9f5] px-8 py-3 rounded-lg hover:bg-[#c06040] transition-colors font-semibold shadow-lg hover:shadow-xl font-display" %>
          <%= link_to "Sign In", new_user_session_path, class: "bg-white text-[#d97757] px-8 py-3 rounded-lg border-2 border-[#d97757] hover:bg-[#e8e6dc] transition-colors font-semibold shadow-md hover:shadow-lg font-display" %>
        <% end %>
      </div>
    </div>

    <!-- How It Works Section -->
    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-[#141413] mb-8 font-display text-center">How It Works</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
          <div class="w-14 h-14 bg-[#d97757]/10 rounded-lg flex items-center justify-center mb-6">
            <div class="text-4xl font-bold text-[#d97757] font-display">1</div>
          </div>
          <h3 class="text-xl font-bold text-[#141413] mb-3 font-display">Sign Up</h3>
          <p class="text-[#b0aea5] font-sans">
            Create your account by signing up. An organization (account) is automatically created for you, and you become the first user.
          </p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
          <div class="w-14 h-14 bg-[#6a9bcc]/10 rounded-lg flex items-center justify-center mb-6">
            <div class="text-4xl font-bold text-[#6a9bcc] font-display">2</div>
          </div>
          <h3 class="text-xl font-bold text-[#141413] mb-3 font-display">Invite Team</h3>
          <p class="text-[#b0aea5] font-sans">
            Once logged in, you can invite team members to join your account and collaborate on business tasks together.
          </p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
          <div class="w-14 h-14 bg-[#788c5d]/10 rounded-lg flex items-center justify-center mb-6">
            <div class="text-4xl font-bold text-[#788c5d] font-display">3</div>
          </div>
          <h3 class="text-xl font-bold text-[#141413] mb-3 font-display">Manage Business</h3>
          <p class="text-[#b0aea5] font-sans">
            Access your organization's dashboard, manage data, and perform all business operations in an isolated, secure environment.
          </p>
        </div>
      </div>
    </div>

    <!-- Demo Credentials Section -->
    <div class="max-w-5xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-[#141413] mb-8 font-display text-center">Demo Login Credentials</h2>
      <p class="text-[#b0aea5] text-center mb-8 font-sans">
        Use these demo accounts to explore the platform. All accounts have the password: <code class="bg-[#e8e6dc] px-2 py-1 rounded text-[#141413] font-mono">password123</code>
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Acme Corporation -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-[#e8e6dc]">
          <div class="bg-[#d97757] p-4">
            <h3 class="text-xl font-bold text-[#faf9f5] font-display">Acme Corporation</h3>
          </div>
          <div class="p-6">
            <div class="space-y-3">
              <div>
                <div class="text-xs text-[#b0aea5] font-sans mb-1">User 1:</div>
                <div class="text-[#141413] font-sans">john@acme.com</div>
              </div>
              <div>
                <div class="text-xs text-[#b0aea5] font-sans mb-1">User 2:</div>
                <div class="text-[#141413] font-sans">jane@acme.com</div>
              </div>
              <%= button_to "Login as John", new_user_session_path(email: 'john@acme.com'), method: :get, class: "w-full mt-4 bg-[#d97757] text-[#faf9f5] py-2 px-4 rounded-lg hover:bg-[#c06040] transition-colors font-display font-medium" %>
            </div>
          </div>
        </div>

        <!-- Globex Industries -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-[#e8e6dc]">
          <div class="bg-[#6a9bcc] p-4">
            <h3 class="text-xl font-bold text-[#faf9f5] font-display">Globex Industries</h3>
          </div>
          <div class="p-6">
            <div class="space-y-3">
              <div>
                <div class="text-xs text-[#b0aea5] font-sans mb-1">User 1:</div>
                <div class="text-[#141413] font-sans">bob@globex.com</div>
              </div>
              <div>
                <div class="text-xs text-[#b0aea5] font-sans mb-1">User 2:</div>
                <div class="text-[#141413] font-sans">alice@globex.com</div>
              </div>
              <%= button_to "Login as Bob", new_user_session_path(email: 'bob@globex.com'), method: :get, class: "w-full mt-4 bg-[#6a9bcc] text-[#faf9f5] py-2 px-4 rounded-lg hover:bg-[#5a8eb0] transition-colors font-display font-medium" %>
            </div>
          </div>
        </div>

        <!-- Soylent Corp -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-[#e8e6dc]">
          <div class="bg-[#788c5d] p-4">
            <h3 class="text-xl font-bold text-[#faf9f5] font-display">Soylent Corp</h3>
          </div>
          <div class="p-6">
            <div class="space-y-3">
              <div>
                <div class="text-xs text-[#b0aea5] font-sans mb-1">User 1:</div>
                <div class="text-[#141413] font-sans">charlie@soylent.com</div>
              </div>
              <div>
                <div class="text-xs text-[#b0aea5] font-sans mb-1">User 2:</div>
                <div class="text-[#141413] font-sans">diane@soylent.com</div>
              </div>
              <div>
                <div class="text-xs text-[#b0aea5] font-sans mb-1">User 3:</div>
                <div class="text-[#141413] font-sans">eve@soylent.com</div>
              </div>
              <%= button_to "Login as Charlie", new_user_session_path(email: 'charlie@soylent.com'), method: :get, class: "w-full mt-4 bg-[#788c5d] text-[#faf9f5] py-2 px-4 rounded-lg hover:bg-[#677b50] transition-colors font-display font-medium" %>
            </div>
          </div>
        </div>
      </div>

      <p class="text-sm text-[#b0aea5] text-center mt-6 font-sans">
        Note: Clicking login buttons will take you to the login page with the email pre-filled. Enter password: <code class="bg-[#e8e6dc] px-2 py-1 rounded text-[#141413] font-mono">password123</code>
      </p>
    </div>

    <!-- Features Section -->
    <div class="max-w-5xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-[#141413] mb-8 font-display text-center">Key Features</h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
          <div class="w-14 h-14 bg-[#d97757]/10 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-[#d97757]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5-10v5a2 2 0 012 2h10a2 2 0 012-2V7a2 2 0 00-2-2h-2m-2 0a2 2 0 00-2 2v2m10-6V9a2 2 0 00-2-2h-2"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#141413] mb-3 font-display">Multi-Tenant Architecture</h3>
          <p class="text-[#b0aea5] font-sans">
            Each organization has its own isolated workspace with complete data separation and security.
          </p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
          <div class="w-14 h-14 bg-[#788c5d]/10 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-[#788c5d]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12m2 0H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#141413] mb-3 font-display">Account Management</h3>
          <p class="text-[#b0aea5] font-sans">
            Manage multiple team members within your organization with role-based access control.
          </p>
        </div>

        <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow border border-[#e8e6dc]">
          <div class="w-14 h-14 bg-[#6a9bcc]/10 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-[#6a9bcc]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-[#141413] mb-3 font-display">Data Security</h3>
          <p class="text-[#b0aea5] font-sans">
            Enterprise-grade security with encrypted passwords and isolated database records per tenant.
          </p>
        </div>
      </div>
    </div>

    <!-- Getting Started Section -->
    <div class="max-w-4xl mx-auto">
      <div class="bg-white rounded-xl shadow-lg p-8 border border-[#e8e6dc]">
        <h2 class="text-2xl font-bold text-[#141413] mb-6 font-display text-center">Getting Started</h2>

        <div class="space-y-4">
          <div class="flex items-start gap-4 p-4 rounded-lg bg-[#faf9f5]">
            <div class="w-8 h-8 bg-[#d97757] rounded-full flex items-center justify-center text-[#faf9f5] font-bold font-display flex-shrink-0">1</div>
            <div>
              <h3 class="font-bold text-[#141413] font-display">Sign Up</h3>
              <p class="text-[#b0aea5] font-sans text-sm">Create your account by providing your email and password. An organization will be automatically created for you.</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 rounded-lg bg-[#faf9f5]">
            <div class="w-8 h-8 bg-[#d97757] rounded-full flex items-center justify-center text-[#faf9f5] font-bold font-display flex-shrink-0">2</div>
            <div>
              <h3 class="font-bold text-[#141413] font-display">Explore Your Dashboard</h3>
              <p class="text-[#b0aea5] font-sans text-sm">After logging in, access your organization's dashboard to start managing your business.</p>
            </div>
          </div>

          <div class="flex items-start gap-4 p-4 rounded-lg bg-[#faf9f5]">
            <div class="w-8 h-8 bg-[#d97757] rounded-full flex items-center justify-center text-[#faf9f5] font-bold font-display flex-shrink-0">3</div>
            <div>
              <h3 class="font-bold text-[#141413] font-display">Invite Team Members</h3>
              <p class="text-[#b0aea5] font-sans text-sm">Share access with colleagues by inviting them to join your account (coming soon).</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="mt-20 bg-[#141413] rounded-2xl p-12 text-center text-[#faf9f5] shadow-xl max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-4 font-display">Ready to Get Started?</h2>
      <p class="text-[#b0aea5] text-lg mb-8 max-w-2xl mx-auto font-sans">
        Join thousands of users who are already experiencing the power of our multi-tenant business management platform.
      </p>
      <div class="flex gap-4 justify-center">
        <% if user_signed_in? %>
          <%= link_to "Go to Dashboard", "#", class: "bg-white text-[#141413] px-8 py-3 rounded-lg hover:bg-[#e8e6dc] transition-colors font-semibold shadow-lg hover:shadow-xl font-display" %>
        <% else %>
          <%= link_to "Create Free Account", new_user_registration_path, class: "bg-[#d97757] text-[#faf9f5] px-8 py-3 rounded-lg hover:bg-[#c06040] transition-colors font-semibold shadow-lg hover:shadow-xl font-display" %>
          <%= link_to "Use Demo Account", new_user_session_path, class: "bg-[#faf9f5] text-[#141413] px-8 py-3 rounded-lg border-2 border-[#141413] hover:bg-[#e8e6dc] transition-colors font-semibold shadow-md hover:shadow-lg font-display" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
